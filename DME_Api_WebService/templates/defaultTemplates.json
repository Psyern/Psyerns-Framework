    "Error": "<!DOCTYPE html>\n<!--\n    Psyerns_Framework \u2014 DME_Api Web Service\n\n    Original work Copyright (c) daemonforge \u2014 DayZ-UniversalApi (AGPL-3.0)\n      https://github.com/daemonforge/DayZ-UniveralApi\n    Modifications & integration Copyright (c) 2026 Psyern / Deadmans Echo\n    Modified by Deadmans Echo, 2026.   [AGPL section 5(a) change notice]\n\n    This file is part of Psyerns_Framework and is licensed under the\n    GNU Affero General Public License v3.0. See LICENSE in the repo root.\n    SPDX-License-Identifier: AGPL-3.0-only\n-->\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n/* water.css v2 (dark) \u2014 MIT License, Copyright (c) Kognise \u2014 https://github.com/kognise/water.css \u2014 bundled locally instead of a CDN */\nbody{font-family:system-ui,-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen,Ubuntu,Cantarell,Fira Sans,Droid Sans,Helvetica Neue,sans-serif;line-height:1.4;max-width:800px;margin:20px auto;padding:0 10px;color:#dbdbdb;background:#202b38;text-rendering:optimizeLegibility}button,input,textarea{transition:background-color .1s linear,border-color .1s linear,color .1s linear,box-shadow .1s linear,transform .1s ease}h1{font-size:2.2em;margin-top:0}h1,h2,h3,h4,h5,h6{margin-bottom:12px}h1,h2,h3,h4,h5,h6,strong{color:#fff}b,h1,h2,h3,h4,h5,h6,strong,th{font-weight:600}blockquote{border-left:4px solid rgba(0,150,191,.67);margin:1.5em 0;padding:.5em 1em;font-style:italic}blockquote>footer{margin-top:10px;font-style:normal}address,blockquote cite{font-style:normal}a[href^=mailto]:before{content:\"\ud83d\udce7 \"}a[href^=tel]:before{content:\"\ud83d\udcde \"}a[href^=sms]:before{content:\"\ud83d\udcac \"}button,input[type=button],input[type=checkbox],input[type=submit]{cursor:pointer}input:not([type=checkbox]):not([type=radio]),select{display:block}button,input,select,textarea{color:#fff;background-color:#161f27;font-family:inherit;font-size:inherit;margin-right:6px;margin-bottom:6px;padding:10px;border:none;border-radius:6px;outline:none}button,input:not([type=checkbox]):not([type=radio]),select,textarea{-webkit-appearance:none}textarea{margin-right:0;width:100%;box-sizing:border-box;resize:vertical}button,input[type=button],input[type=submit]{padding-right:30px;padding-left:30px}button:hover,input[type=button]:hover,input[type=submit]:hover{background:#324759}button:focus,input:focus,select:focus,textarea:focus{box-shadow:0 0 0 2px rgba(0,150,191,.67)}button:active,input[type=button]:active,input[type=checkbox]:active,input[type=radio]:active,input[type=submit]:active{transform:translateY(2px)}button:disabled,input:disabled,select:disabled,textarea:disabled{cursor:not-allowed;opacity:.5}::-webkit-input-placeholder{color:#a9a9a9}:-ms-input-placeholder{color:#a9a9a9}::-ms-input-placeholder{color:#a9a9a9}::placeholder{color:#a9a9a9}a{text-decoration:none;color:#41adff}a:hover{text-decoration:underline}code,kbd{background:#161f27;color:#ffbe85;padding:5px;border-radius:6px}pre>code{padding:10px;display:block;overflow-x:auto}img{max-width:100%}hr{border:none;border-top:1px solid #dbdbdb}table{border-collapse:collapse;margin-bottom:10px;width:100%}td,th{padding:6px;text-align:left}th{border-bottom:1px solid #dbdbdb}tbody tr:nth-child(2n){background-color:#161f27}::-webkit-scrollbar{height:10px;width:10px}::-webkit-scrollbar-track{background:#161f27;border-radius:6px}::-webkit-scrollbar-thumb{background:#324759;border-radius:6px}::-webkit-scrollbar-thumb:hover{background:#415c73}\n    </style>\n\n    <title>Error - <%= Type %></title>\n\n    <!--\n        Passed Variables\n        `TheError` This will contain the error text, for the user, or the system error.\n        `Type` The type of error passed, you can use this for more advanced templating.\n                - \"UserNotFound\" - player was not part of the servers discord\n                - \"RoleRequired\" - player was missing the role specificed in the config\n                - \"Blacklisted\" - the player has the blacklisted role specificed in the config\n                - \"Conflict\" - player has already linked this discord to another steam id in your account\n                - \"AlreadyLinked\" - player has already linked a discord to the speicifed Steam Id\n\n                - \"System\" - System Errors\n                - \"Database\" - Error Connecting to the database\n                - \"BadURL\" - A bad URL\n                - \"Discord\" - An error from the discord call\n                - \"NotSetup\" - the discord intergration settings arn't set up on the API\n    -->\n</head>\n<body>\n\n    <% if (Type == \"AlreadyLinked\") { %>\n\n        <h1>You have already linked your discord account</h1>\n\n    <% } else if (Type == \"Conflict\") { %>\n\n        <h1>This discord account is already linked with another Steam Id</h1>\n\n    <% } else if ( Type == \"UserNotFound\") { %>\n\n        <h1>User not found in our disocrd</h1>\n\n\n    <% } else if ( Type == \"RoleRequired\") { %>\n\n        <h1>You are required to have a specific role in Discord</h1>\n\n    <% } else { %>\n\n        <h1>Error Invalid Link or Request</h1>\n    <code style=\"display: block; width: 100%; white-space: pre;\">\n<%= TheError %>\n    </code>\n\n    <% } %>\n\n    <footer style=\"margin-top: 2em; font-size: 0.85em; text-align: center; opacity: 0.7;\">\n        <a href=\"https://deadmans-echo.de\" rel=\"noopener\">Source (AGPL-3.0)</a>\n    </footer>\n</body>\n</html>",
    "Login": "<!DOCTYPE html>\n<!--\n    Psyerns_Framework \u2014 DME_Api Web Service\n\n    Original work Copyright (c) daemonforge \u2014 DayZ-UniversalApi (AGPL-3.0)\n      https://github.com/daemonforge/DayZ-UniveralApi\n    Modifications & integration Copyright (c) 2026 Psyern / Deadmans Echo\n    Modified by Deadmans Echo, 2026.   [AGPL section 5(a) change notice]\n\n    This file is part of Psyerns_Framework and is licensed under the\n    GNU Affero General Public License v3.0. See LICENSE in the repo root.\n    SPDX-License-Identifier: AGPL-3.0-only\n-->\n<html lang=\"en\">\n    <head>\n        <meta charset=\"UTF-8\">\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <style>\n/* water.css v2 (dark) \u2014 MIT License, Copyright (c) Kognise \u2014 https://github.com/kognise/water.css \u2014 bundled locally instead of a CDN */\nbody{font-family:system-ui,-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen,Ubuntu,Cantarell,Fira Sans,Droid Sans,Helvetica Neue,sans-serif;line-height:1.4;max-width:800px;margin:20px auto;padding:0 10px;color:#dbdbdb;background:#202b38;text-rendering:optimizeLegibility}button,input,textarea{transition:background-color .1s linear,border-color .1s linear,color .1s linear,box-shadow .1s linear,transform .1s ease}h1{font-size:2.2em;margin-top:0}h1,h2,h3,h4,h5,h6{margin-bottom:12px}h1,h2,h3,h4,h5,h6,strong{color:#fff}b,h1,h2,h3,h4,h5,h6,strong,th{font-weight:600}blockquote{border-left:4px solid rgba(0,150,191,.67);margin:1.5em 0;padding:.5em 1em;font-style:italic}blockquote>footer{margin-top:10px;font-style:normal}address,blockquote cite{font-style:normal}a[href^=mailto]:before{content:\"\ud83d\udce7 \"}a[href^=tel]:before{content:\"\ud83d\udcde \"}a[href^=sms]:before{content:\"\ud83d\udcac \"}button,input[type=button],input[type=checkbox],input[type=submit]{cursor:pointer}input:not([type=checkbox]):not([type=radio]),select{display:block}button,input,select,textarea{color:#fff;background-color:#161f27;font-family:inherit;font-size:inherit;margin-right:6px;margin-bottom:6px;padding:10px;border:none;border-radius:6px;outline:none}button,input:not([type=checkbox]):not([type=radio]),select,textarea{-webkit-appearance:none}textarea{margin-right:0;width:100%;box-sizing:border-box;resize:vertical}button,input[type=button],input[type=submit]{padding-right:30px;padding-left:30px}button:hover,input[type=button]:hover,input[type=submit]:hover{background:#324759}button:focus,input:focus,select:focus,textarea:focus{box-shadow:0 0 0 2px rgba(0,150,191,.67)}button:active,input[type=button]:active,input[type=checkbox]:active,input[type=radio]:active,input[type=submit]:active{transform:translateY(2px)}button:disabled,input:disabled,select:disabled,textarea:disabled{cursor:not-allowed;opacity:.5}::-webkit-input-placeholder{color:#a9a9a9}:-ms-input-placeholder{color:#a9a9a9}::-ms-input-placeholder{color:#a9a9a9}::placeholder{color:#a9a9a9}a{text-decoration:none;color:#41adff}a:hover{text-decoration:underline}code,kbd{background:#161f27;color:#ffbe85;padding:5px;border-radius:6px}pre>code{padding:10px;display:block;overflow-x:auto}img{max-width:100%}hr{border:none;border-top:1px solid #dbdbdb}table{border-collapse:collapse;margin-bottom:10px;width:100%}td,th{padding:6px;text-align:left}th{border-bottom:1px solid #dbdbdb}tbody tr:nth-child(2n){background-color:#161f27}::-webkit-scrollbar{height:10px;width:10px}::-webkit-scrollbar-track{background:#161f27;border-radius:6px}::-webkit-scrollbar-thumb{background:#324759;border-radius:6px}::-webkit-scrollbar-thumb:hover{background:#415c73}\n        </style>\n\n        <!--\n            Passed Variables\n            `SteamId` The steam id of the player.\n            `Login_URL` The link the player needs to click to be sent to discord\n            `Connected` true/false true if the player already has .\n        -->\n\n        <title>Connect To Discord \u2014 Deadmans Echo</title>\n    </head>\n    <body>\n        <% if (Connected) { %>\n            <h2>You are attemping to link to a steam account that has already been connected</h2>\n        <% } else { %>\n        <div class=\"container\">\n          <div id=\"SteamCard\">\n            <table style=\"overflow: hidden; width: fit-content; display: inline-block; margin: 15px; border-radius: 15px; border: solid 1px #161f27; box-shadow:  1px 2px rgba(6, 13, 39, 0.3);\">\n                <tbody>\n                    <tr>\n                        <td>Steam Id: </td>\n                        <td id=\"cardId\"><%= SteamId %></td>\n                    </tr>\n                </tbody>\n            </table>\n          </div>\n          <button onclick=\"login()\" style=\"padding: 7px 10px; margin: 15px; display: flex; align-items: center; font-size: 1.5em; font-weight: bold; border: solid 1px #161f27; box-shadow:  1px 2px rgba(6, 13, 39, 0.3);\"><svg style=\"height: 32px; width: 32px; fill: var(--form-text); margin-right:10px; display: inline\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 200 200\"><path d=\"M118.4 84.2c-5.7 0-10.2 4.9-10.2 11s4.6 11 10.2 11c5.7 0 10.2-4.9 10.2-11s-4.6-11-10.2-11zm-36.5 0c-5.7 0-10.2 4.9-10.2 11s4.6 11 10.2 11c5.7 0 10.2-4.9 10.2-11 .1-6.1-4.5-11-10.2-11zM167 1H33c-11.3 0-20.5 9.2-20.5 20.5v134c0 11.3 9.2 20.5 20.5 20.5h113.4l-5.3-18.3 12.8 11.8 12.1 11.1 21.6 18.7V21.5C187.5 10.2 178.3 1 167 1zm-38.6 129.5l-6.6-8c13.1-3.7 18.1-11.8 18.1-11.8-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.4-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.2-1.8-1-2.8-1.7-2.8-1.7s4.8 7.9 17.5 11.7c-3 3.8-6.7 8.2-6.7 8.2-22.1-.7-30.5-15.1-30.5-15.1 0-31.9 14.4-57.8 14.4-57.8 14.4-10.7 28-10.4 28-10.4l1 1.2c-18 5.1-26.2 13-26.2 13s2.2-1.2 5.9-2.8C76 54 84.5 52.8 88 52.4c.6-.1 1.1-.2 1.7-.2 6.1-.8 13-1 20.2-.2 9.5 1.1 19.7 3.9 30.1 9.5 0 0-7.9-7.5-24.9-12.6l1.4-1.6s13.7-.3 28 10.4c0 0 14.4 25.9 14.4 57.8 0-.1-8.4 14.3-30.5 15z\"/></svg> <span style=\"display: inline-block;\">Connect</span></button>\n        </div>\n        <% } %>\n        <script>\n            function login(){\n                window.location.replace(`<%= Login_URL %>`);\n            };\n        </script>\n        <footer style=\"margin-top: 2em; font-size: 0.85em; text-align: center; opacity: 0.7;\">\n            <a href=\"https://deadmans-echo.de\" rel=\"noopener\">Source (AGPL-3.0)</a>\n        </footer>\n    </body>\n</html>",
    "Success": "<!DOCTYPE html>\n<!--\n    Psyerns_Framework \u2014 DME_Api Web Service\n\n    Original work Copyright (c) daemonforge \u2014 DayZ-UniversalApi (AGPL-3.0)\n      https://github.com/daemonforge/DayZ-UniveralApi\n    Modifications & integration Copyright (c) 2026 Psyern / Deadmans Echo\n    Modified by Deadmans Echo, 2026.   [AGPL section 5(a) change notice]\n\n    This file is part of Psyerns_Framework and is licensed under the\n    GNU Affero General Public License v3.0. See LICENSE in the repo root.\n    SPDX-License-Identifier: AGPL-3.0-only\n-->\n<html lang=\"en\">\n    <head>\n        <meta charset=\"UTF-8\">\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <style>\n/* water.css v2 (dark) \u2014 MIT License, Copyright (c) Kognise \u2014 https://github.com/kognise/water.css \u2014 bundled locally instead of a CDN */\nbody{font-family:system-ui,-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen,Ubuntu,Cantarell,Fira Sans,Droid Sans,Helvetica Neue,sans-serif;line-height:1.4;max-width:800px;margin:20px auto;padding:0 10px;color:#dbdbdb;background:#202b38;text-rendering:optimizeLegibility}button,input,textarea{transition:background-color .1s linear,border-color .1s linear,color .1s linear,box-shadow .1s linear,transform .1s ease}h1{font-size:2.2em;margin-top:0}h1,h2,h3,h4,h5,h6{margin-bottom:12px}h1,h2,h3,h4,h5,h6,strong{color:#fff}b,h1,h2,h3,h4,h5,h6,strong,th{font-weight:600}blockquote{border-left:4px solid rgba(0,150,191,.67);margin:1.5em 0;padding:.5em 1em;font-style:italic}blockquote>footer{margin-top:10px;font-style:normal}address,blockquote cite{font-style:normal}a[href^=mailto]:before{content:\"\ud83d\udce7 \"}a[href^=tel]:before{content:\"\ud83d\udcde \"}a[href^=sms]:before{content:\"\ud83d\udcac \"}button,input[type=button],input[type=checkbox],input[type=submit]{cursor:pointer}input:not([type=checkbox]):not([type=radio]),select{display:block}button,input,select,textarea{color:#fff;background-color:#161f27;font-family:inherit;font-size:inherit;margin-right:6px;margin-bottom:6px;padding:10px;border:none;border-radius:6px;outline:none}button,input:not([type=checkbox]):not([type=radio]),select,textarea{-webkit-appearance:none}textarea{margin-right:0;width:100%;box-sizing:border-box;resize:vertical}button,input[type=button],input[type=submit]{padding-right:30px;padding-left:30px}button:hover,input[type=button]:hover,input[type=submit]:hover{background:#324759}button:focus,input:focus,select:focus,textarea:focus{box-shadow:0 0 0 2px rgba(0,150,191,.67)}button:active,input[type=button]:active,input[type=checkbox]:active,input[type=radio]:active,input[type=submit]:active{transform:translateY(2px)}button:disabled,input:disabled,select:disabled,textarea:disabled{cursor:not-allowed;opacity:.5}::-webkit-input-placeholder{color:#a9a9a9}:-ms-input-placeholder{color:#a9a9a9}::-ms-input-placeholder{color:#a9a9a9}::placeholder{color:#a9a9a9}a{text-decoration:none;color:#41adff}a:hover{text-decoration:underline}code,kbd{background:#161f27;color:#ffbe85;padding:5px;border-radius:6px}pre>code{padding:10px;display:block;overflow-x:auto}img{max-width:100%}hr{border:none;border-top:1px solid #dbdbdb}table{border-collapse:collapse;margin-bottom:10px;width:100%}td,th{padding:6px;text-align:left}th{border-bottom:1px solid #dbdbdb}tbody tr:nth-child(2n){background-color:#161f27}::-webkit-scrollbar{height:10px;width:10px}::-webkit-scrollbar-track{background:#161f27;border-radius:6px}::-webkit-scrollbar-thumb{background:#324759;border-radius:6px}::-webkit-scrollbar-thumb:hover{background:#415c73}\n        </style>\n\n\n        <!--\n            Passed Variables\n            `SteamId` The steam id of the player.\n            `DiscordId` The Discord Id.\n            `DiscordUsername` The Discord Username.\n            `DiscordDiscriminator` The unquie identification for the Discord Username.\n            `DiscordAvatar` The avatar of the discord.\n        -->\n\n        <title>Successfully Linked \u2014 Deadmans Echo</title>\n    </head>\n    <body style=\"max-width: 600px; text-align: center;\">\n        <h1 style=\"color: #DCEDC8;\">You have successfully connected your Steam account to the Deadmans Echo Discord</h1>\n        <footer style=\"margin-top: 2em; font-size: 0.85em; text-align: center; opacity: 0.7;\">\n            <a href=\"https://deadmans-echo.de\" rel=\"noopener\">Source (AGPL-3.0)</a>\n        </footer>\n    </body>\n</html>"
