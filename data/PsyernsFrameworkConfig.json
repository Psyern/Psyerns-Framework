{
    "EnableDebugLogging": false,
    "DefaultRetryCount": 3,
    "QueueMaxSize": 100,
    "EnableServerStartNotification": false,
    "ServerStartDelaySeconds": 30,
    "ServerName": "DayZ Server",
    "Endpoints": [
        {
            "Name": "WordPress",
            "BaseUrl": "https://your-site.com/wp-json/psyern/v1",
