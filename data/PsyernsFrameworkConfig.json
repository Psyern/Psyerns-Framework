        "https://your-site.com/wp-json/psyern/v1/killfeed"
    ],
    "AlertRules": [
        {
            "TriggerType": "zone_enter",
            "Radius": 200.0,
            "PosX": 7500.0,
            "PosY": 0.0,
            "PosZ": 7500.0,
            "WebhookUrl": "https://your-site.com/wp-json/psyern/v1/alerts",
